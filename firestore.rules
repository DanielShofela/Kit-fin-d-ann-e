rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    match /kits/{kitId} {
      allow read, write: if true;
    }
    match /settings/{settingsId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
  }
}
